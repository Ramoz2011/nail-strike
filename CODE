"""
 Function Name: onMousePress
 Description: When the mouse is pressed, he slashes
 Inputs: mouseX and mouseY are not used
 Outputs: Moves the nail and roates it and turns the affect True
"""

def onMousePress(x,y):
    nail.rotateAngle+=150
    nail.centerX=420-nail.centerX
    nail.centerY+=60
    affect.visible=True
   
"""
 Function Name: onMouseRelease
 Description: When the mouse is released, he stop slashing
 Inputs: mouseX and mouseY are not used
 Outputs: Turns everything back to normall
"""
def onMouseRelease(x,y):
    nail.rotateAngle=0
    nail.centerX=337
    nail.centerY=238
    affect.visible=False
